APP_ENV=prod
SERVER_PORT=8080
APP_PUBLIC_BASE_URL=https://api.leanmate.app

DB_URL=jdbc:postgresql://prod-db.internal:5432/leanmate
DB_USERNAME=leanmate_app
DB_PASSWORD=change-me-prod-secret
FLYWAY_ENABLED=true

JWT_ISSUER=leanmate
JWT_SECRET=change-me-prod-use-a-strong-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_DAYS=30

APPLE_CLIENT_ID=app.leanmate.ios
APPLE_TEAM_ID=change-me
APPLE_KEY_ID=change-me
APPLE_PRIVATE_KEY=change-me

STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=https://s3.example.com
STORAGE_BUCKET=leanmate-prod
STORAGE_ACCESS_KEY=change-me
STORAGE_SECRET_KEY=change-me
STORAGE_PUBLIC_BASE_URL=https://assets.leanmate.app

AI_PROVIDER=openai
AI_API_KEY=change-me
AI_BASE_URL=https://api.openai.com/v1
AI_DIET_PHOTO_MODEL=change-me
AI_DIET_TEXT_MODEL=change-me
AI_DAILY_REPORT_MODEL=change-me
AI_REQUEST_TIMEOUT_SECONDS=30
AI_DAILY_REPORT_RETRY_LIMIT=1

MAX_UPLOAD_IMAGE_SIZE_MB=8
DAILY_AI_RECOGNITION_LIMIT=30
DAILY_REPORT_GENERATE_LIMIT=3

LOG_LEVEL=INFO
LOG_SQL=false
