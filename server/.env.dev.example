APP_ENV=dev
SERVER_PORT=8080
APP_PUBLIC_BASE_URL=https://dev-api.leanmate.app

DB_URL=jdbc:postgresql://dev-db.internal:5432/leanmate
DB_USERNAME=leanmate_app
DB_PASSWORD=change-me-dev-secret
FLYWAY_ENABLED=true

JWT_ISSUER=leanmate-dev
JWT_SECRET=change-me-dev-use-a-strong-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_DAYS=30

CORS_ALLOWED_ORIGIN_PATTERNS=https://dev-app.leanmate.app
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE_SECONDS=3600

APPLE_CLIENT_ID=app.leanmate.ios
APPLE_TEAM_ID=change-me
APPLE_KEY_ID=change-me
APPLE_PRIVATE_KEY=change-me

STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=https://s3-dev.example.com
STORAGE_BUCKET=leanmate-dev
STORAGE_ACCESS_KEY=change-me
STORAGE_SECRET_KEY=change-me
STORAGE_PUBLIC_BASE_URL=https://assets-dev.leanmate.app

AI_PROVIDER=placeholder
AI_API_KEY=
AI_BASE_URL=
AI_DIET_PHOTO_PROVIDER=placeholder
AI_DIET_TEXT_PROVIDER=deepseek
AI_DAILY_REPORT_PROVIDER=deepseek
DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DIET_PHOTO_MODEL=change-me
AI_DIET_TEXT_MODEL=deepseek-v4-flash
AI_DAILY_REPORT_MODEL=deepseek-v4-flash
AI_REQUEST_TIMEOUT_SECONDS=30
AI_DAILY_REPORT_RETRY_LIMIT=1

MAX_UPLOAD_IMAGE_SIZE_MB=8
DAILY_AI_RECOGNITION_LIMIT=30
DAILY_REPORT_GENERATE_LIMIT=3

LOG_LEVEL=INFO
LOG_SQL=false
ACCESS_LOG_ENABLED=true
ACCESS_LOG_INCLUDE_QUERY_KEYS=true
ACCESS_LOG_SLOW_THRESHOLD_MS=1000
AI_CALL_LOG_ENABLED=true
AI_CALL_LOG_SAVE_DEBUG_PAYLOAD=false
